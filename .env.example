# ApexGTM Automated Outbound OS — Environment Variables
# Rename this file to .env and fill in your keys
# NEVER commit .env to GitHub

# ─── Apollo ───────────────────────────────────────────
APOLLO_API_KEY=

# ─── Anthropic (Claude) ───────────────────────────────
ANTHROPIC_API_KEY=

# ─── HubSpot ──────────────────────────────────────────
HUBSPOT_API_KEY=

# ─── Google Service Account ───────────────────────────
GOOGLE_SERVICE_ACCOUNT_PATH=./config/google-service-account.json

# ─── Slack ────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ─── Supabase ─────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── n8n ──────────────────────────────────────────────
N8N_WEBHOOK_URL=

# ─── Clay ─────────────────────────────────────────────
CLAY_API_KEY=
