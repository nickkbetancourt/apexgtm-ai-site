# ApexGTM Company Research & Outreach - environment variables
# Copy this file to .env in this folder and fill in real values.

# Anthropic API key. If unset, the workflow automatically falls back to mock data.
ANTHROPIC_API_KEY=

# Optional: override the default model used for generation.
ANTHROPIC_MODEL=claude-sonnet-5

# Optional: force mock mode even if an API key is configured (useful for demos/tests).
APEX_FORCE_MOCK=false

# Optional: timeout in seconds for fetching a prospect's website.
REQUEST_TIMEOUT_SECONDS=10
